0-0000-0000-000000000000}</GalleryObjectID><RNOffset>0</RNOffset><RNLength>0</RNLength><IgnoreNC>0</IgnoreNC><VerifyState>1</VerifyState><GenerateCode>1</GenerateCode><Notes></Notes><Comments></Comments><SQL><![CDATA[CREATE OR REPLACE TRIGGER TRG_USERS_CONFIG_LEVEL
BEFORE INSERT ON USERS_CONFIG_LEVEL
FOR EACH ROW
BEGIN
    IF :NEW.GAME_ID IS NULL OR :NEW.GAME_ID = 0 THEN
        SELECT SEC_USERS_CONFIG_LEVEL.NEXTVAL INTO :NEW.GAME_ID FROM DUAL;
    END IF;
END;
/
]]></SQL><Caption>TRG_USERS_CONFIG_LEVEL</Caption><GenerateSQLOnly>0</GenerateSQLOnly><DbOwner/><EachRow>0</EachRow><EventDelete>0</EventDelete><EventInsert>1</EventInsert><EventUpdate>0</EventUpdate><EventUpdateColumns></EventUpdateColumns><Fire>BEFORE</Fire><Referencing_new></Referencing_new><Referencing_old></Referencing_old><WhenCondition></WhenCondition><Follows></Follows><IsEnable>1</IsEnable></PERTriggerEntityOR11></Triggers><DbOwner/><Schema/><AccessDriverType>ORACLE_LOADER</AccessDriverType><AccessParameters></AccessParameters><Directory/><GlobalTemp>0</GlobalTemp><IsExternalTable>0</IsExternalTable><IsUsingClob>0</IsUsingClob><LocationSpecifierList></LocationSpecifierList><PhysicalProp></PhysicalProp><RejectLimit></RejectLimit><TableProp></TableProp><Tablespace/><TempPreserve>0</TempPreserve></PEREntityOR11><PEREntityOR11 ObjectType="2002" CSAOName="PEREntityOR11" CSAOCaption="Entity"><Id>{43AD7931-010E-4C7C-850E-DE61B14E5E32}</Id><Name>user_Config_General</Name><Ordinal>0</Ordinal><GlobalOrder>8</GlobalOrder><GalleryItemID>{00000000-0000-0000-0000-000000000000}</GalleryItemID><GalleryID>{00000000-0000-0000-0000-000000000000}</GalleryID><GalleryObjectID>{00000000-0000-0000-0000-000000000000}</GalleryObjectID><RNOffset>0</RNOffset><RNLength>0</RNLength><IgnoreNC>0</IgnoreNC><VerifyState>4</VerifyState><GenerateCode>1</GenerateCode><BeforeScript></BeforeScript><AfterScript></AfterScript><Notes></Notes><Comments></Comments><Caption>user_Config_General</Caption><Size>0</Size><DataWarehouseType>0</DataWarehouseType><DevNotes></DevNotes><ExternalDependent>0</ExternalDependent><ExternalDependentList></ExternalDependentList><Relations><Id>{BAF89BCD-DEDE-472A-8C9C-B8C0E833A518}</Id></Relations><Attributes><PERAttributeOR11 ObjectType="2003" CSAOName="PERAttributeOR11" CSAOCaption="Attribute"><Id>{1E348C5A-A3CF-4C97-931C-6FED10B5BBCC}</Id><Name>user_General_id</Name><Ordinal>0</Ordinal><GlobalOrder>0</GlobalOrder><GalleryItemID>{00000000-0000-0000-0000-000000000000}